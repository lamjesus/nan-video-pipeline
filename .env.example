# Secretos y valores por máquina. NO se commitea (.env está en .gitignore).
# Los DEFAULTS compartidos (modelos, voz, providers) viven en config.yml.

# Cluster NaN (API OpenAI-compatible). Pide estos valores en la plataforma.
NAN_BASE_URL=https://...   # base URL del cluster
NAN_API_KEY=...            # token del miembro (SECRETO)

# --- Overrides opcionales de config.yml ---
# Descomenta sólo si quieres algo distinto al default de config.yml.
# NAN_VOICE_ID=ef_dora                      # default en config.yml: em_alex
# MEDIA_PROVIDERS=wikimedia,pexels,local    # default en config.yml: wikimedia,local

# Provider opt-in Pexels: sin key se salta (SECRETO).
# PEXELS_API_KEY=...
