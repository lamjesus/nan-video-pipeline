# Cluster NaN (API OpenAI-compatible). Pide estos valores en la plataforma.
NAN_BASE_URL=https://...   # base URL del cluster
NAN_API_KEY=...            # token del miembro

# Voz por defecto de kokoro: em_alex (masculina) | ef_dora (femenina)
NAN_VOICE_ID=em_alex

# Proveedores de media (csv, orden de prioridad).
# Opciones: wikimedia, local, pexels, freepik
# Por defecto: wikimedia,local
# MEDIA_PROVIDERS=wikimedia,pexels,local

# API keys para providers opt-in (opcionales, sin key se saltan)
# PEXELS_API_KEY=...
# FREEPIK_API_KEY=...
